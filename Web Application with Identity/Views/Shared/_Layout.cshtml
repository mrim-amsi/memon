                <input class="form-control" type="text" placeholder="ابحث عن ..." aria-label="Search for..." aria-describedby="btnNavbarSearch" />
                <button class="btn btn-primary" id="btnNavbarSearch" type="button"><i class="fas fa-search"></i></button>
            </div>
        </form>
        <!-- Navbar-->
        <ul class="navbar-nav ms-auto ms-md-0 me-3 me-lg-4">
            <li class="nav-item dropdown m-5">
                <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="fas fa-user fa-fw"></i></a>
                <ul class="dropdown-menu dropdown-menu-start" aria-labelledby="navbarDropdown">
                    <li><a class="dropdown-item" href="#!">إعدادات</a></li>
                    <li><a class="dropdown-item" href="#!">نشاطات</a></li>
                    <li><a class="dropdown-item"  asp-controller="Home" asp-action="Privacy">الحصوصية</a></li>
                    <li><hr class="dropdown-divider" /></li>
                      @if (User.Identity.IsAuthenticated)
                    {
                        <li><a class="dropdown-item" asp-controller="account" asp-action="Logout">تسجيل خروج</a></li>
                    //    <li><a class="dropdown-item" asp-controller="account" asp-action="Logout"> @User.Identity.Name </a></li>
                    }
                    else
                    {
                            <li>
                                <a class="dropdown-item" asp-controller="account" asp-action="login">تسجيل دخول</a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-controller="account" asp-action="register">تسجيل</a>
                            </li>
                    }
                </ul>
            </li>
        </ul>
