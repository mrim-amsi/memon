<main>
    <div class="">
        <h1 class="mt-4">الوجبات</h1>
        <ol class="breadcrumb mb-4">
                         <li class="breadcrumb-item"> </a></li>
                    <li class="breadcrumb-item active"><a href="index.html">لوحة التحكم</a></li>
                    <li class="">الوجبات</li>
        </ol>
                <div class="d-flex justify-content-end m-5">
            <a class="btn btn-primary" asp-action="Add" asp-controller="Meals">أضافة وجبة</a>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <i class="fas fa-table me-1"></i>
@*                DataTable Example
*@            </div>



            <div class="card-body">
                <table id="datatablesSimple">
                    <thead>
                        <tr>
                            <th>
                                 صورة الوجبة
                            </th>
                            <th>
                                رقم الوجبة
                            </th>
                            <th>
                                اسم الوجبة
                            </th>
                            <th>
                                الوصف
                            </th>
                            <th>
                                السعر
                            </th>
                            <th>
                               اسم المطعم
                            </th>
                            <th>
                                 الكمية
                            </th>
                            <th>
                                افعال
                            </th>
                           </tr>
                            </thead>
                            <tbody>

             @foreach (meal item in Model)
             {
            <tr>
                <td>
                    <img style="width:50px;height:50px; object-fit:cover; border-radius:50%;" src="~/Images/@item.ImageName" />
                </td>
                <td>
                    @item.Id
                </td>
                <td>
                    @item.Title
                </td>
                 <td>
                    @item.Body
                </td>
                 <td>
                  @item.Price
                </td>
                 <td>
                  @item.Restaurant.Name
                 </td>
                  <td>
                  @item.Quantity
                   </td>
                @* <td>
                    @item.CreatedAt.ToString("dd/MM/yyyy")
                </td>
               <td>
                  @item.Category.Name
                </td>*@
             @*   <td>
                    @foreach (var tag in item.PostTags)
                    {
                        @tag.Tag.Name
                    }
                </td>*@
                <td class="text-center">

                                    <form asp-controller="Meals" asp-action="Edit" method="post" style="display: inline;">
                                        <input value="@item.Id" hidden name="id" />
                                        <button type="submit" class="btn btn-primary">
                                            <i class="fa fa-edit"></i>
                                            تعديل
                                        </button>

                                    </form>
                                    <form asp-controller="Meals" asp-action="Remove" method="post" asp-route-id="@item.Id" style="display: inline;">
                                        <button type="submit" class="btn btn-danger">
                                            <i class="bi bi-trash"></i>
                                            حدف
                                        </button>

                                    </form></td>
            </tr>
        }
    </tbody>
</table>
            </div>
        </div>
    </div>
</main>
